APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Optional extra origins (defaults in config/cors.php include Vercel back-office)
# CORS_ALLOWED_ORIGINS=https://another-spa.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (use DB_URL *or* host/user/pass fields below) ---
DB_CONNECTION=mysql
# Full string from your provider, e.g. mysql://user:pass@host:3306/dbname
DB_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
# Remote MySQL (e.g. AWS RDS): use bundled CA; see LOCAL_SETUP.md
MYSQL_ATTR_SSL_CA=storage/certs/global-bundle.pem
MYSQL_SSL_VERIFY_SERVER_CERT=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REGISTRATION_USE_DEMO_OTP=true
REGISTRATION_DEMO_OTP_CODE=000000

# Generate with: php artisan jwt:secret
JWT_SECRET=

DOJAH_BASE_URL=https://api.dojah.io
DOJAH_APP_ID=

# Swwipe identity lookup (NIN GET, BVN POST) — https://app.swwipe.com/api/v1
SWWIPE_BASE_URL=https://app.swwipe.com/api/v1
SWWIPE_API_KEY=
SWWIPE_TIMEOUT=30

ONBOARDING_MAX_DOCUMENT_BYTES=10485760
DOJAH_SECRET_KEY=
